// This module has moved to std::math::rand
// These tests are kept for backward compatibility

use std::math;
use std::testing::{assert_eq};

// Dummy test to prevent "No test found" error
pub fn test_module_moved() {
    // Verify the module exists in math
    let rng: Rng = Rng::new();
    let r: i32 = rng.next_i32();
    assert_eq(true, true);
}
