use std::testing::{assert_eq};
use std::string::{
    StringSlice
};

pub fn test_basic_methods() {
    let s: str = "hello";
    assert_eq(s.len(), 5);
    assert_eq(s.is_empty(), false);
    assert_eq("".is_empty(), true);
    
    let c0: i32 = s.char_at(0);
    let c4: i32 = s.char_at(4);
    assert_eq(c0, 104); // 'h'
    assert_eq(c4, 111); // 'o'
}

pub fn test_bytes() {
    let s: str = "abc";
    let b: []byte = s.bytes();
    assert_eq(b.len(), 3);
    let b0: i32 = b[0];
    let b1: i32 = b[1];
    let b2: i32 = b[2];
    assert_eq(b0, 97); // 'a'
    assert_eq(b1, 98); // 'b'
    assert_eq(b2, 99); // 'c'
}

pub fn test_concat_equals() {
    let a: str = "foo";
    let b: str = "bar";
    let c: str = a.join(b);
    assert_eq(c, "foobar");
    assert_eq(a.eq("foo"), true);
    assert_eq(a.eq(b), false);
}

pub fn test_starts_ends_with() {
    let s: str = "foobar";
    assert_eq(s.starts_with("foo"), true);
    assert_eq(s.starts_with("bar"), false);
    assert_eq(s.starts_with("foobar"), true);
    assert_eq(s.starts_with("foobar_long"), false);
    
    assert_eq(s.ends_with("bar"), true);
    assert_eq(s.ends_with("foo"), false);
    assert_eq(s.ends_with("foobar"), true);
    assert_eq(s.ends_with("short_foobar"), false);
}

pub fn test_index_of_contains() {
    let s: str = "hello world hello";
    
    // index_of
    assert_eq(s.index_of("hello"), 0);
    assert_eq(s.index_of("world"), 6);
    assert_eq(s.index_of("notfound"), 0 - 1);
    assert_eq(s.index_of(""), 0);
    
    // last_index_of
    assert_eq(s.last_index_of("hello"), 12);
    assert_eq(s.last_index_of("world"), 6);
    assert_eq(s.last_index_of("notfound"), 0 - 1);
    assert_eq(s.last_index_of(""), 17);
    
    // contains
    assert_eq(s.contains("world"), true);
    assert_eq(s.contains("notfound"), false);
}

pub fn test_compare() {
    assert_eq("abc".compare("abc") == 0, true);
    assert_eq("abc".compare("abd") < 0, true);
    assert_eq("abd".compare("abc") > 0, true);
    assert_eq("abc".compare("abcd") < 0, true);
    assert_eq("abcd".compare("abc") > 0, true);
}

pub fn test_slice() {
    let s: str = "abcdef";
    let slice: StringSlice = StringSlice::new(s, 1, 4); // "bcd"
    assert_eq(slice.len(), 3);
    
    let c0: i32 = slice.char_at(0);
    let c1: i32 = slice.char_at(1);
    let c2: i32 = slice.char_at(2);
    assert_eq(c0, 98);  // 'b'
    assert_eq(c1, 99);  // 'c'
    assert_eq(c2, 100); // 'd'
}
