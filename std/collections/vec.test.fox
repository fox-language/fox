use std::testing::{assert_eq};
use std::collections::{Vec, Option, VecIterator};

pub fn test_vec_basic() {
    let v: Vec<i32> = Vec<i32>::new();
    assert_eq(v.len(), 0);
    
    v.push(10);
    v.push(20);
    v.push(30);
    
    assert_eq(v.len(), 3);
    
    let o1: Option<i32> = v.get(0);
    let o1_is_some: bool = match o1 { Some(val) => true, None() => false };
    assert_eq(true, o1_is_some);
    match o1 {
        Some(val) => { assert_eq(val, 10); },
        None() => {},
    };
    
    let o2: Option<i32> = v.get(1);
    let o2_is_some: bool = match o2 { Some(val) => true, None() => false };
    assert_eq(true, o2_is_some);
    match o2 {
        Some(val) => { assert_eq(val, 20); },
        None() => {},
    };

    let o3: Option<i32> = v.get(2);
    let o3_is_some: bool = match o3 { Some(val) => true, None() => false };
    assert_eq(true, o3_is_some);
    match o3 {
        Some(val) => { assert_eq(val, 30); },
        None() => {},
    };
    
    v.set(1, 99);
    let o2_new: Option<i32> = v.get(1);
    let o2_new_is_some: bool = match o2_new { Some(val) => true, None() => false };
    assert_eq(true, o2_new_is_some);
    match o2_new {
        Some(val) => { assert_eq(val, 99); },
        None() => {},
    };
    
    let p: Option<i32> = v.pop();
    let p_is_some: bool = match p { Some(val) => true, None() => false };
    assert_eq(true, p_is_some);
    match p {
        Some(val) => { assert_eq(val, 30); },
        None() => {},
    };
    assert_eq(v.len(), 2);
}

pub fn test_vec_with_len() {
    let v: Vec<str> = Vec<str>::with_len(3);
    assert_eq(v.len(), 3);
    
    v.set(0, "a");
    v.set(1, "b");
    v.set(2, "c");
    
    let o1: Option<str> = v.get(0);
    let o1_is_some: bool = match o1 { Some(val) => true, None() => false };
    assert_eq(true, o1_is_some);
    match o1 {
        Some(val) => { assert_eq(val, "a"); },
        None() => {},
    };

    let o2: Option<str> = v.get(1);
    let o2_is_some: bool = match o2 { Some(val) => true, None() => false };
    assert_eq(true, o2_is_some);
    match o2 {
        Some(val) => { assert_eq(val, "b"); },
        None() => {},
    };

    let o3: Option<str> = v.get(2);
    let o3_is_some: bool = match o3 { Some(val) => true, None() => false };
    assert_eq(true, o3_is_some);
    match o3 {
        Some(val) => { assert_eq(val, "c"); },
        None() => {},
    };
}

pub fn test_vec_with_cap() {
    let v: Vec<i32> = Vec<i32>::with_cap(5);
    assert_eq(v.len(), 0);
    
    v.push(1);
    v.push(2);
    v.push(3);
    v.push(4);
    v.push(5);
    
    assert_eq(v.len(), 5);
    
    let o5: Option<i32> = v.get(4);
    let o5_is_some: bool = match o5 { Some(val) => true, None() => false };
    assert_eq(true, o5_is_some);
    match o5 {
        Some(val) => { assert_eq(val, 5); },
        None() => {},
    };
}

pub fn test_vec_grow() {
    let v: Vec<i32> = Vec<i32>::new();
    v.push(1);
    v.push(2);
    
    // Explicit grow
    v.grow(10);
    
    assert_eq(v.len(), 2);
    
    let o1: Option<i32> = v.get(0);
    let o1_is_some: bool = match o1 { Some(val) => true, None() => false };
    assert_eq(true, o1_is_some);
    match o1 {
        Some(val) => { assert_eq(val, 1); },
        None() => {},
    };

    let o2: Option<i32> = v.get(1);
    let o2_is_some: bool = match o2 { Some(val) => true, None() => false };
    assert_eq(true, o2_is_some);
    match o2 {
        Some(val) => { assert_eq(val, 2); },
        None() => {},
    };
    
    v.push(3);
    assert_eq(v.len(), 3);
    
    let o3: Option<i32> = v.get(2);
    let o3_is_some: bool = match o3 { Some(val) => true, None() => false };
    assert_eq(true, o3_is_some);
    match o3 {
        Some(val) => { assert_eq(val, 3); },
        None() => {},
    };
}

pub fn test_vec_iterator() {
    let v: Vec<i32> = Vec<i32>::new();
    v.push(100);
    v.push(200);
    v.push(300);

    let iter: VecIterator<i32> = v.iter();
    let sum: i32 = 0;
    while let Some(val) = iter.next() {
        sum = sum + val;
    }
    assert_eq(sum, 600);
}
