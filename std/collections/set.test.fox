use std::testing::{assert_eq};
use std::collections::{Set, Option, SetIterator};
use std::fmt::{sprintf};

pub fn test_set_i32() {
    let m: Set<i32> = Set<i32>::new();
    m.add(1);
    m.add(2);
    m.add(1);

    assert_eq(m.size(), 2);
    assert_eq(m.has(1), true);
    assert_eq(m.has(2), true);
    assert_eq(m.has(3), false);
    m.delete(1);
    assert_eq(m.size(), 1);
    assert_eq(m.has(1), false);
    assert_eq(m.has(2), true);
}

pub fn test_set_iterator() {
    let s: Set<i32> = Set<i32>::new();
    s.add(10);
    s.add(20);
    s.add(30);

    let iter: SetIterator<i32> = s.iter();
    let sum: i32 = 0;
    while let Some(val) = iter.next() {
        sum = sum + val;
    }
    assert_eq(sum, 60);
}

